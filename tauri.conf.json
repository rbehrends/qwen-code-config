{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qwen Code Config",
  "version": "0.1.0",
  "identifier": "dev.pragma.qwen-code-config",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Qwen Code Config",
        "width": 1200,
        "height": 800,
        "minWidth": 860,
        "minHeight": 560
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "JSON Settings",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ]
  }
}
